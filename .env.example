# ═══════════════════════════════════════════════════════════════
#  环境变量配置示例
#  复制此文件为 .env.local 并填入实际值
# ═══════════════════════════════════════════════════════════════

# ── 应用配置 ───────────────────────────────────────────────────
VITE_APP_NAME=短线AI交易系统
VITE_APP_VERSION=1.0.0

# ── API 配置 ───────────────────────────────────────────────────
# 后端API地址（如果有独立后端）
VITE_API_BASE_URL=/api

# ── Tushare 配置 ───────────────────────────────────────────────
# Tushare Pro API Token
# 获取方式: https://tushare.pro/register
# 免费用户: 2000积分/分钟，200次/分钟
# 付费用户: 根据积分不同有不同调用频率
VITE_TUSHARE_TOKEN=your_tushare_token_here

# Tushare 代理服务地址
# 本地开发: http://localhost:5000/api
# 生产环境: https://your-domain.com/api
VITE_TUSHARE_API_BASE=http://localhost:5000/api

# ── 其他数据源配置（可选） ─────────────────────────────────────
# 东方财富API（免费，无需Token）
VITE_EASTMONEY_API_BASE=https://push2.eastmoney.com/api

# 新浪财经API（免费，无需Token）
VITE_SINA_API_BASE=https://hq.sinajs.cn

# ── WebSocket 实时推送配置 ─────────────────────────────────────
# WebSocket服务地址
# 本地开发: http://localhost:5001
# 生产环境: https://your-domain.com/ws
VITE_WS_URL=http://localhost:5001

# ── PostgreSQL 数据库配置（后端使用） ──────────────────────────
# 数据库连接URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/short_win_trader

# Redis配置（可选，用于缓存和消息队列）
REDIS_URL=redis://localhost:6379/0

# ── 安全配置 ───────────────────────────────────────────────────
# WebSocket密钥
SECRET_KEY=short-win-ai-trader-secret-key-change-in-production

# ── 调试配置 ───────────────────────────────────────────────────
VITE_DEBUG=true
VITE_LOG_LEVEL=debug
